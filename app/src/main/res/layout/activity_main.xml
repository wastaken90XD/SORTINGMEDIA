<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#121212">

    <!-- Top toolbar -->
    <LinearLayout
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:background="#1A1A2E"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp">

        <TextView
            android:id="@+id/appTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Media Sorter"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginEnd="16dp"/>

        <EditText
            android:id="@+id/searchBar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_weight="1"
            android:hint="Search by name or tag…"
            android:textColorHint="#888888"
            android:textColor="#FFFFFF"
            android:background="#2A2A3E"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:inputType="text"
            android:imeOptions="actionSearch"
            android:singleLine="true"/>

        <Button
            android:id="@+id/btnGroupBy"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Group ▾"
            android:textSize="12sp"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btnDashboard"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="Dashboard"
            android:textSize="12sp"
            android:layout_marginStart="8dp"/>

        <Button
            android:id="@+id/btnSettings"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="⚙"
            android:textSize="14sp"
            android:layout_marginStart="8dp"/>

    </LinearLayout>

    <!-- Three panel layout -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

        <!-- Left: File browser -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/fileBrowser"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:background="#161616"
            android:clipToPadding="false"
            android:padding="4dp"/>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A2A3E"/>

        <!-- Center: Preview -->
        <FrameLayout
            android:id="@+id/previewPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="4"
            android:background="#0F0F1A"/>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="#2A2A3E"/>

        <!-- Right: Tag panel -->
        <LinearLayout
            android:id="@+id/tagPanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"
            android:orientation="vertical"
            android:background="#161626"
            android:padding="8dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="TAGS"
                android:textColor="#E94560"
                android:textSize="11sp"
                android:textStyle="bold"
                android:layout_marginBottom="6dp"/>

            <EditText
                android:id="@+id/tagSearch"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:hint="Filter tags…"
                android:textColorHint="#666666"
                android:textColor="#FFFFFF"
                android:background="#2A2A3E"
                android:paddingStart="8dp"
                android:paddingEnd="8dp"
                android:inputType="text"
                android:singleLine="true"
                android:layout_marginBottom="6dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/tagList"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="6dp">

                <EditText
                    android:id="@+id/newTagInput"
                    android:layout_width="0dp"
                    android:layout_height="36dp"
                    android:layout_weight="1"
                    android:hint="New tag…"
                    android:textColorHint="#666666"
                    android:textColor="#FFFFFF"
                    android:background="#2A2A3E"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp"
                    android:inputType="text"
                    android:singleLine="true"/>

                <Button
                    android:id="@+id/btnAddTag"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="+"
                    android:textSize="18sp"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
