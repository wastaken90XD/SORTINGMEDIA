<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0F1A">

    <!-- Image preview -->
    <ImageView
        android:id="@+id/imagePreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="fitCenter"
        android:visibility="gone"/>

    <!-- Video preview -->
    <VideoView
        android:id="@+id/videoPreview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"/>

    <!-- Unsupported format -->
    <LinearLayout
        android:id="@+id/unsupportedPreview"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">

        <TextView
            android:id="@+id/unsupportedIcon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⚠"
            android:textSize="48sp"
            android:textColor="#888888"/>

        <TextView
            android:id="@+id/unsupportedText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#888888"
            android:textSize="14sp"
            android:gravity="center"
            android:layout_marginTop="8dp"/>

    </LinearLayout>

    <!-- Bottom overlay — file details + action buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:background="#CC0F0F1A">

        <!-- File details -->
        <LinearLayout
            android:id="@+id/fileDetailsBar"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="8dp">

            <TextView
                android:id="@+id/detailFileName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#FFFFFF"
                android:textSize="12sp"
                android:textStyle="bold"
                android:singleLine="true"
                android:ellipsize="middle"/>

            <TextView
                android:id="@+id/detailMeta"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#AAAAAA"
                android:textSize="10sp"
                android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/detailPath"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#666666"
                android:textSize="9sp"
                android:layout_marginTop="2dp"
                android:singleLine="true"
                android:ellipsize="start"/>

        </LinearLayout>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:orientation="horizontal"
            android:background="#1A1A2E">

            <Button
                android:id="@+id/btnTags"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="TAGS"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#E94560"/>

            <Button
                android:id="@+id/btnSkip"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="SKIP"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#444466"/>

            <Button
                android:id="@+id/btnFlag"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="FLAG"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#AA6600"/>

            <Button
                android:id="@+id/btnDone"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="DONE"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#226622"/>

            <!-- Position counter -->
            <TextView
                android:id="@+id/positionCounter"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:gravity="center"
                android:textColor="#AAAAAA"
                android:textSize="11sp"
                android:text="0 / 0"/>

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
