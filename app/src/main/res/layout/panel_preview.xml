<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0F0F1A">

    <!-- Image / Video area — fills all space above details -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <ImageView
            android:id="@+id/imagePreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"
            android:visibility="gone"/>

        <VideoView
            android:id="@+id/videoPreview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/unsupportedPreview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <TextView
                android:id="@+id/unsupportedIcon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚠"
                android:textSize="48sp"
                android:textColor="#888888"/>

            <TextView
                android:id="@+id/unsupportedText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="#888888"
                android:textSize="14sp"
                android:gravity="center"
                android:layout_marginTop="8dp"/>

        </LinearLayout>

        <!-- D-pad floats over image — no background -->
        <LinearLayout
            android:id="@+id/dpadContainer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="8dp"
            android:orientation="vertical"
            android:gravity="center"
            android:background="@null">

            <Button
                android:id="@+id/dpadUp"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="▲"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#CCE94560"
                android:layout_gravity="center"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_gravity="center">

                <Button
                    android:id="@+id/dpadLeft"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="◄"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#CC2A2A3E"/>

                <Button
                    android:id="@+id/dpadCenter"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="●"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#CCE94560"
                    android:layout_marginStart="2dp"
                    android:layout_marginEnd="2dp"/>

                <Button
                    android:id="@+id/dpadRight"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:text="►"
                    android:textSize="10sp"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="#CC2A2A3E"/>

            </LinearLayout>

            <Button
                android:id="@+id/dpadDown"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:text="▼"
                android:textSize="10sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#CCE94560"
                android:layout_gravity="center"/>

        </LinearLayout>

        <!-- Tag side panel — slides in from right -->
        <LinearLayout
            android:id="@+id/tagSidePanel"
            android:layout_width="140dp"
            android:layout_height="match_parent"
            android:layout_gravity="end"
            android:orientation="vertical"
            android:background="#EE1A1A2E"
            android:padding="6dp"
            android:visibility="gone">

            <Spinner
                android:id="@+id/tagListSpinner"
                android:layout_width="match_parent"
                android:layout_height="36dp"
                android:background="#2A2A3E"/>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#2A2A3E"
                android:layout_marginTop="4dp"
                android:layout_marginBottom="4dp"/>

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/sidePanelTagList"
                android:layout_width="match_parent"
                android:layout_height="match_parent"/>

        </LinearLayout>

    </FrameLayout>

    <!-- File details — below image, not overlaid -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="6dp">

        <TextView
            android:id="@+id/detailFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            android:textStyle="bold"
            android:singleLine="true"
            android:ellipsize="middle"/>

        <TextView
            android:id="@+id/detailMeta"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#AAAAAA"
            android:textSize="9sp"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

    <!-- Action bar — below file details -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:orientation="horizontal"
        android:background="#121212">

        <Button
            android:id="@+id/btnSkip"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="SKIP"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#444466"/>

        <Button
            android:id="@+id/btnFlag"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="FLAG"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#AA6600"/>

        <Button
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="DONE"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#226622"/>

        <Button
            android:id="@+id/btnPrev"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="◄"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A3E"/>

        <Button
            android:id="@+id/btnNext"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="►"
            android:textSize="14sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A3E"/>

        <TextView
            android:id="@+id/positionCounter"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:gravity="center"
            android:textColor="#AAAAAA"
            android:textSize="10sp"
            android:text="0 / 0"/>

        <Button
            android:id="@+id/btnTogglePanel"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:text="≡"
            android:textSize="16sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#2A2A3E"/>

    </LinearLayout>

</LinearLayout>
